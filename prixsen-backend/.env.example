# ============================================================
# PRIXSEN Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer .env dans git
# ============================================================

# Serveur
PORT=3001
NODE_ENV=development   # development | production

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=prixsen_db

# JWT — OBLIGATOIRE : générer des secrets aléatoires forts
# Commande : openssl rand -base64 64
JWT_SECRET=REMPLACER_PAR_SECRET_ALEATOIRE_64_CHARS_MINIMUM
JWT_REFRESH_SECRET=REMPLACER_PAR_AUTRE_SECRET_ALEATOIRE_64_CHARS_MINIMUM
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (optionnel — laisser vide pour désactiver)
# Obtenir sur https://console.cloud.google.com/
GOOGLE_CLIENT_ID=

# Upload fichiers
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880   # 5 MB en octets

# CORS — URL du frontend autorisé
FRONTEND_URL=http://localhost:5173
